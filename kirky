<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:       #111113;
  --bg2:      #18181b;
  --bg3:      #1f1f23;
  --bg4:      #26262b;
  --line:     rgba(255,255,255,0.07);
  --line2:    rgba(255,255,255,0.12);
  --text:     #f0ede8;
  --text2:    #9d9890;
  --text3:    #5a564f;
  --amber:    #d4974a;
  --amber2:   #f0b96a;
  --amber-bg: rgba(212,151,74,0.08);
  --red:      #c04a3a;
  --sans:     'DM Sans', system-ui, sans-serif;
  --serif:    'DM Serif Display', Georgia, serif;
}

html { font-size: 15px; scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--sans);
  font-weight: 300;
  line-height: 1.65;
  -webkit-font-smoothing: antialiased;
}

/* ─── NAV ─────────────────────────────────────── */
nav {
  position: sticky; top: 0; z-index: 200;
  height: 52px;
  background: rgba(17,17,19,0.88);
  backdrop-filter: blur(16px) saturate(1.4);
  border-bottom: 1px solid var(--line);
  display: flex; align-items: center;
  padding: 0 40px; gap: 0;
}
.nav-brand {
  font-family: var(--serif);
  font-size: 17px;
  color: var(--text);
  margin-right: auto;
  letter-spacing: 0.01em;
}
.nav-brand em { font-style: italic; color: var(--amber); }
.nav-links { display: flex; gap: 4px; margin-right: 20px; }
.nav-links a {
  font-size: 12px; font-weight: 400;
  letter-spacing: 0.05em;
  color: var(--text3);
  text-decoration: none;
  padding: 6px 12px;
  border-radius: 6px;
  transition: background 0.15s, color 0.15s;
}
.nav-links a:hover { background: var(--bg3); color: var(--text2); }
.nav-pill {
  font-size: 11px; font-weight: 400;
  letter-spacing: 0.06em;
  padding: 4px 12px;
  border-radius: 20px;
  background: var(--amber-bg);
  color: var(--amber);
  border: 1px solid rgba(212,151,74,0.25);
}

/* ─── LAYOUT ──────────────────────────────────── */
.page { max-width: 1060px; margin: 0 auto; padding: 0 40px 100px; }

/* ─── HERO ────────────────────────────────────── */
.hero {
  padding: 64px 0 60px;
  display: grid;
  grid-template-columns: 1fr 300px;
  gap: 56px;
  align-items: start;
  border-bottom: 1px solid var(--line);
}
.hero-eyebrow {
  font-size: 11px; font-weight: 500;
  letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--text3); margin-bottom: 14px;
  display: flex; align-items: center; gap: 8px;
}
.hero-eyebrow::before {
  content: '';
  display: inline-block; width: 20px; height: 1px;
  background: var(--amber);
}
h1 {
  font-family: var(--serif);
  font-size: clamp(40px, 5.5vw, 64px);
  font-weight: 400;
  line-height: 1.06;
  letter-spacing: -0.01em;
  color: var(--text);
  margin-bottom: 22px;
}
h1 em { font-style: italic; color: var(--amber2); }
.hero-lead {
  font-size: 15px; color: var(--text2); font-weight: 300;
  max-width: 440px; line-height: 1.8;
}
.hero-tags {
  display: flex; flex-wrap: wrap; gap: 8px; margin-top: 28px;
}
.htag {
  font-size: 12px; font-weight: 400;
  padding: 5px 13px;
  border-radius: 20px;
  border: 1px solid var(--line2);
  color: var(--text2);
  background: var(--bg2);
}

/* hero aside card */
.aside-card {
  background: var(--bg2);
  border: 1px solid var(--line);
  border-radius: 10px;
  overflow: hidden;
  margin-top: 8px;
}
.ac-header {
  padding: 14px 18px;
  border-bottom: 1px solid var(--line);
  font-size: 10px; font-weight: 500;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--text3);
  display: flex; align-items: center; justify-content: space-between;
}
.ac-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: var(--amber);
  box-shadow: 0 0 8px rgba(212,151,74,0.6);
}
.ac-row {
  display: flex; justify-content: space-between; align-items: baseline;
  padding: 10px 18px;
  border-bottom: 1px solid var(--line);
  transition: background 0.12s;
}
.ac-row:hover { background: var(--bg3); }
.ac-row:last-child { border-bottom: none; }
.ac-key {
  font-size: 11px; color: var(--text3);
  letter-spacing: 0.06em;
}
.ac-val {
  font-size: 13px; color: var(--text); text-align: right;
}
.ac-val a { color: var(--amber); text-decoration: none; }
.ac-val a:hover { text-decoration: underline; }

/* ─── SECTION ─────────────────────────────────── */
.section { padding: 52px 0; border-bottom: 1px solid var(--line); }
.section:last-of-type { border-bottom: none; }
.sh {
  display: flex; align-items: baseline; gap: 14px;
  margin-bottom: 32px;
}
.sh-num {
  font-family: var(--serif);
  font-style: italic;
  font-size: 13px;
  color: var(--amber);
  min-width: 24px;
}
h2 {
  font-family: var(--serif);
  font-size: 26px; font-weight: 400;
  color: var(--text); letter-spacing: -0.01em;
}
.sh-line { flex: 1; height: 1px; background: var(--line); }

/* ─── DATA FIELDS ─────────────────────────────── */
.fields {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1px;
  background: var(--line);
  border: 1px solid var(--line);
  border-radius: 10px;
  overflow: hidden;
}
.field {
  background: var(--bg);
  padding: 16px 18px;
  transition: background 0.12s;
}
.field:hover { background: var(--bg2); }
.fk {
  font-size: 10px; font-weight: 500;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--text3); margin-bottom: 5px;
}
.fv {
  font-size: 14px; color: var(--text); word-break: break-all;
}
.fv a { color: var(--amber); text-decoration: none; }
.fv a:hover { text-decoration: underline; }

/* ─── LINKS ───────────────────────────────────── */
.links {
  display: flex; flex-direction: column; gap: 1px;
  background: var(--line);
  border: 1px solid var(--line);
  border-radius: 10px; overflow: hidden;
}
.lrow {
  background: var(--bg);
  display: grid;
  grid-template-columns: 110px 1fr 28px;
  align-items: center;
  gap: 20px;
  padding: 15px 18px;
  text-decoration: none; color: inherit;
  transition: background 0.12s;
}
.lrow:hover { background: var(--bg2); }
.lp {
  font-size: 10px; font-weight: 500;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--text3);
}
.lh { font-size: 13px; color: var(--text2); }
.la {
  font-size: 16px; color: var(--text3);
  text-align: right;
  transition: transform 0.18s, color 0.18s;
}
.lrow:hover .la { transform: translate(3px,-3px); color: var(--amber); }

/* ─── TIMELINE ────────────────────────────────── */
.tl { display: flex; flex-direction: column; }
.tli {
  display: grid;
  grid-template-columns: 68px 1px 1fr;
  gap: 0 28px;
}
.tly {
  font-family: var(--serif);
  font-style: italic;
  font-size: 14px; color: var(--text3);
  padding-top: 2px; text-align: right;
}
.tls {
  display: flex; flex-direction: column; align-items: center;
}
.tln {
  width: 9px; height: 9px; border-radius: 50%;
  background: var(--bg);
  border: 1.5px solid var(--amber);
  flex-shrink: 0; margin-top: 5px;
  position: relative; z-index: 1;
}
.tlr { flex: 1; width: 1px; background: var(--line); margin: 5px 0 0; }
.tlb { padding: 0 0 34px; }
.tlt {
  font-family: var(--serif);
  font-size: 18px; font-weight: 400;
  color: var(--text); margin-bottom: 6px;
  line-height: 1.3;
}
.tld {
  font-size: 13px; color: var(--text2);
  font-weight: 300; line-height: 1.75;
  max-width: 540px;
}

/* ─── PHOTOS ──────────────────────────────────── */
.photos {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10px;
}
.pc {
  border-radius: 8px; overflow: hidden;
  background: var(--bg2);
  border: 1px solid var(--line);
  display: flex; flex-direction: column;
}
.pc-img { overflow: hidden; }
.pc-img img {
  width: 100%; aspect-ratio: 1; object-fit: cover;
  display: block;
  transition: transform 0.45s cubic-bezier(.25,.46,.45,.94), filter 0.3s;
  filter: saturate(0.7) brightness(0.92);
}
.pc:hover .pc-img img {
  transform: scale(1.06);
  filter: saturate(1) brightness(1);
}
.pc-cap {
  padding: 9px 11px;
  font-size: 10px; color: var(--text3);
  font-weight: 400; line-height: 1.4;
  border-top: 1px solid var(--line);
  flex: 1;
}

/* ─── TAGS ────────────────────────────────────── */
.tags { display: flex; flex-wrap: wrap; gap: 8px; }
.tag {
  font-size: 12px; font-weight: 300;
  padding: 7px 15px;
  border-radius: 8px;
  border: 1px solid var(--line);
  color: var(--text2);
  background: var(--bg2);
  transition: all 0.15s;
  cursor: default;
}
.tag:hover {
  background: var(--bg3);
  border-color: var(--line2);
  color: var(--text);
}
.tag strong { font-weight: 500; color: var(--text); }

/* ─── FOOTER ──────────────────────────────────── */
footer {
  margin-top: 56px;
  padding-top: 28px;
  border-top: 1px solid var(--line);
  display: flex; justify-content: space-between;
  flex-wrap: wrap; gap: 10px;
}
.fbrand {
  font-family: var(--serif);
  font-style: italic;
  font-size: 15px; color: var(--text3);
}
.fmeta { font-size: 11px; color: var(--text3); line-height: 1.8; text-align: right; }

/* ─── RESPONSIVE ──────────────────────────────── */
@media (max-width: 820px) {
  .hero { grid-template-columns: 1fr; gap: 36px; }
  .photos { grid-template-columns: repeat(3,1fr); }
  .nav-links { display: none; }
  .page { padding: 0 20px 80px; }
  nav { padding: 0 20px; }
}
@media (max-width: 500px) {
  .photos { grid-template-columns: repeat(2,1fr); }
  .lrow { grid-template-columns: 80px 1fr 20px; gap: 12px; }
  .fmeta { text-align: left; }
}
</style>
